NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias if your Supabase dashboard still labels it as anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
DISABLE_BILLING_GATE=true

# AI scan tiers.
# All scan tiers use the same OPENAI_API_KEY.
# AI_STANDARD_SCAN_MODEL is used for normal receipt scans.
# AI_PLUS_SCAN_MODEL is used for more careful scans.
# AI_PRO_SCAN_MODEL is used for premium/highest accuracy scans.
# The selected model IDs must be available to the OpenAI account.
# For first Vercel test deploy, keep AI_PROVIDER=mock.
AI_PROVIDER=mock
OPENAI_API_KEY=
AI_STANDARD_SCAN_MODEL=gpt-5.4-mini
AI_PLUS_SCAN_MODEL=gpt-5.4
AI_PRO_SCAN_MODEL=gpt-5.5

# Legacy fallback only. Prefer AI_STANDARD_SCAN_MODEL / AI_PLUS_SCAN_MODEL / AI_PRO_SCAN_MODEL.
AI_FAST_MODEL=
AI_ACCURATE_MODEL=
ANTHROPIC_API_KEY=
